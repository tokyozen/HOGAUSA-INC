Options -MultiViews -Indexes
RewriteEngine On
RewriteBase /

# ---------------------------------------------------------------
# 1. Redirect /index.html to the bare root /
# ---------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# ---------------------------------------------------------------
# 2. Redirect any other request with a .html extension to the
#    clean extensionless URL (301 permanent — good for SEO)
# ---------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ---------------------------------------------------------------
# 3. Internally serve the matching .html file for clean URLs
#    so direct visits, refreshes, and bookmarks keep working
# ---------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ---------------------------------------------------------------
# 4. Custom 404 page (optional but recommended)
# ---------------------------------------------------------------
ErrorDocument 404 /index.html
